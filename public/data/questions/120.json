      "step_title": "Need Help?",
      "content": "<p><em style=\"color: rgb(26, 26, 26); background-color: rgb(255, 255, 255);\">Contact QPOS Support via live chat in your QPOS app or email </em><em style=\"color: rgb(217, 122, 13); background-color: rgb(255, 255, 255);\"><u><a href=\"mailto:support@storehub.com\" rel=\"noopener noreferrer\" target=\"_blank\">support@QPOS.com</a></u></em><em style=\"color: rgb(26, 26, 26); background-color: rgb(255, 255, 255);\">.</em></p><p></p>",
