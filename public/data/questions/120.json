    {
      "id": 398,
      "question_id": 120,
      "step_order": 3,
      "step_title": "What Are Sales Reports and Why Are They Important?",
      "content": "<p><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">Sales reports are powerful tools that show you how your business is performing.</span></p><p></p><p><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">They break down your sales data in different ways, helping you understand:</span></p><ul><li><strong style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">What sells best:</strong><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\"> Identify your most popular products or categories.</span></li><li><strong style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">When you&#39;re busiest:</strong><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\"> See your sales trends by hour, day, or month.</span></li><li><strong style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">How customers pay:</strong><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\"> Understand popular payment methods.</span></li><li><strong style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">Employee performance:</strong><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\"> Track sales made by your team.</span></li><li><strong style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\">Overall business health:</strong><span style=\"background-color: rgb(255, 255, 255); color: rgb(26, 26, 26);\"> Get a clear picture of your revenue, discounts, and costs.</span></li></ul>",
      "image_url": null,
      "video_url": null,
      "block_type": "step",
      "images": []
    },
